# ============================================================
# PayFlow — Cloud LLM API Keys (Round-Robin Pool)
# Copy this file to .env and fill in your keys.
# The system picks keys in round-robin order, skipping any
# that are rate-limited or erroring out.
# ============================================================

# ── Anthropic Claude keys (CLAUDE_KEY_1 … CLAUDE_KEY_30) ──
# Used for Event Lab explainability & cloud fallback inference.
# Works with Claude 3.5 Haiku (default) or any claude-* model.
CLAUDE_KEY_1=sk-ant-...
CLAUDE_KEY_2=sk-ant-...
CLAUDE_KEY_3=sk-ant-...
CLAUDE_KEY_4=sk-ant-...
CLAUDE_KEY_5=sk-ant-...
CLAUDE_KEY_6=sk-ant-...
CLAUDE_KEY_7=sk-ant-...
CLAUDE_KEY_8=sk-ant-...
CLAUDE_KEY_9=sk-ant-...
CLAUDE_KEY_10=sk-ant-...
CLAUDE_KEY_11=sk-ant-...
CLAUDE_KEY_12=sk-ant-...
CLAUDE_KEY_13=sk-ant-...
CLAUDE_KEY_14=sk-ant-...
CLAUDE_KEY_15=sk-ant-...

# ── Groq keys (GROQ_KEY_1 … GROQ_KEY_30) ─────────────────
# Used as high-speed fallback when Claude keys are rate-limited.
# Uses llama-3.1-8b-instant by default (very fast, free tier).
GROQ_KEY_1=gsk_...
GROQ_KEY_2=gsk_...
GROQ_KEY_3=gsk_...
GROQ_KEY_4=gsk_...
GROQ_KEY_5=gsk_...
GROQ_KEY_6=gsk_...
GROQ_KEY_7=gsk_...
GROQ_KEY_8=gsk_...
GROQ_KEY_9=gsk_...
GROQ_KEY_10=gsk_...
GROQ_KEY_11=gsk_...
GROQ_KEY_12=gsk_...
GROQ_KEY_13=gsk_...
GROQ_KEY_14=gsk_...
GROQ_KEY_15=gsk_...

# ── Single-key fallbacks (optional) ──────────────────────
# If you only have one Claude or Groq key, set these instead.
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...

# ── Local Ollama (primary LLM — no key needed) ────────────
# The main investigator agent always uses local Ollama first.
# Cloud keys are only used for Event Lab explainability overlay.
OLLAMA_BASE_URL=http://localhost:11434
