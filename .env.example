# ============================================================
# PayFlow — Cloud LLM API Keys (Round-Robin Pool)
# Copy this file to .env and fill in your keys.
#
# The system maintains a separate round-robin cursor per provider,
# rotates keys on every call, and applies escalating cooldowns
# on rate-limit hits (2min → 10min → 1hr → 24hr).
# A background health checker validates all keys every 5 minutes.
# ============================================================

# ── Anthropic Claude keys (CLAUDE_KEY_1 … CLAUDE_KEY_30) ──
# Used for Event Lab explainability & cloud fallback inference.
# Works with Claude 3.5 Haiku (default) or any claude-* model.
CLAUDE_KEY_1=sk-ant-...
CLAUDE_KEY_2=sk-ant-...
CLAUDE_KEY_3=sk-ant-...
CLAUDE_KEY_4=sk-ant-...
CLAUDE_KEY_5=sk-ant-...
CLAUDE_KEY_6=sk-ant-...
CLAUDE_KEY_7=sk-ant-...
CLAUDE_KEY_8=sk-ant-...
CLAUDE_KEY_9=sk-ant-...
CLAUDE_KEY_10=sk-ant-...
CLAUDE_KEY_11=sk-ant-...
CLAUDE_KEY_12=sk-ant-...
CLAUDE_KEY_13=sk-ant-...
CLAUDE_KEY_14=sk-ant-...
CLAUDE_KEY_15=sk-ant-...
CLAUDE_KEY_16=sk-ant-...
CLAUDE_KEY_17=sk-ant-...
CLAUDE_KEY_18=sk-ant-...
CLAUDE_KEY_19=sk-ant-...
CLAUDE_KEY_20=sk-ant-...
CLAUDE_KEY_21=sk-ant-...
CLAUDE_KEY_22=sk-ant-...
CLAUDE_KEY_23=sk-ant-...
CLAUDE_KEY_24=sk-ant-...
CLAUDE_KEY_25=sk-ant-...
CLAUDE_KEY_26=sk-ant-...
CLAUDE_KEY_27=sk-ant-...
CLAUDE_KEY_28=sk-ant-...
CLAUDE_KEY_29=sk-ant-...
CLAUDE_KEY_30=sk-ant-...

# ── Groq keys (GROQ_KEY_1 … GROQ_KEY_30) ─────────────────
# Used as high-speed fallback when Claude keys are rate-limited.
# Uses llama-3.1-8b-instant by default (very fast, free tier).
GROQ_KEY_1=gsk_...
GROQ_KEY_2=gsk_...
GROQ_KEY_3=gsk_...
GROQ_KEY_4=gsk_...
GROQ_KEY_5=gsk_...
GROQ_KEY_6=gsk_...
GROQ_KEY_7=gsk_...
GROQ_KEY_8=gsk_...
GROQ_KEY_9=gsk_...
GROQ_KEY_10=gsk_...
GROQ_KEY_11=gsk_...
GROQ_KEY_12=gsk_...
GROQ_KEY_13=gsk_...
GROQ_KEY_14=gsk_...
GROQ_KEY_15=gsk_...
GROQ_KEY_16=gsk_...
GROQ_KEY_17=gsk_...
GROQ_KEY_18=gsk_...
GROQ_KEY_19=gsk_...
GROQ_KEY_20=gsk_...
GROQ_KEY_21=gsk_...
GROQ_KEY_22=gsk_...
GROQ_KEY_23=gsk_...
GROQ_KEY_24=gsk_...
GROQ_KEY_25=gsk_...
GROQ_KEY_26=gsk_...
GROQ_KEY_27=gsk_...
GROQ_KEY_28=gsk_...
GROQ_KEY_29=gsk_...
GROQ_KEY_30=gsk_...

# ── Single-key fallbacks (optional) ──────────────────────
# If you only have one Claude or Groq key, set these instead.
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...

# ── Local Ollama (primary LLM — no key needed) ────────────
# The main investigator agent always uses local Ollama first.
# Cloud keys are only used for Event Lab explainability overlay.
OLLAMA_BASE_URL=http://localhost:11434
